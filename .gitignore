# Godot 4+ specific ignores
.godot/
*.import
export.cfg

# Web export output is COMMITTED so Netlify can publish it as static files.
# Rebuild with: godot --headless --export-release Web build/index.html
# (.import artifacts inside build/ stay ignored via *.import above)

# Imported translations (if not stored directly as CSV)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# Local planning docs (specs/plans stay on this machine)
docs/

# System/tool-specific ignores
.DS_Store
Thumbs.db
*.bak
*~
