; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Mythic Vanguard"
run/main_scene="res://title.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")

[audio]

; Web exports default to "sample" playback which bypasses the audio bus
; system entirely — bus mute/volume would have no effect in the browser.
general/default_playback_type.web=1

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[gui]

theme/custom_font="res://assets/fonts/MedievalSharp.ttf"

[input_devices]

pointing/emulate_mouse_from_touch=true

[rendering]

environment/defaults/default_clear_color=Color(0.09, 0.1, 0.14, 1)
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"

[autoload]

GameManager="*res://game_manager.gd"
